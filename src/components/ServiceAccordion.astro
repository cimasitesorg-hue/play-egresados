---
import Icon from "./Icon.astro";
import { withBase } from "@/lib/paths";
import type { Servicio } from "@/data/servicios";
interface Props {
  servicio: Servicio;
  open?: boolean;
}
const { servicio, open = false } = Astro.props;
---

<details class="acc reveal" open={open} data-has-bg={servicio.bg ? "1" : undefined}>
  {
    servicio.bg && (
      <div class="acc__bg" aria-hidden="true">
        <img src={withBase(servicio.bg)} alt="" width="760" height="1040" loading="lazy" />
      </div>
    )
  }
  <summary class="acc__summary">
    <span class="acc__icon">
      <Icon name={servicio.icon} size={24} />
    </span>
    <span class="acc__head">
      <span class="acc__title">{servicio.titulo}</span>
      <span class="acc__resumen">{servicio.resumen}</span>
    </span>
    <span class="acc__chevron" aria-hidden="true">
      <Icon name="arrow-down" size={20} />
    </span>
  </summary>
  <div class="acc__body">
    <ul class="acc__list">
      {
        servicio.detalle.map((d) => (
          <li>
            <Icon name="check" size={18} />
            <span>{d}</span>
          </li>
        ))
      }
    </ul>
  </div>
</details>

<style>
  .acc {
    position: relative;
    background: linear-gradient(
      180deg,
      oklch(0.27 0.045 262 / 0.45),
      oklch(0.19 0.035 262 / 0.45)
    );
    border: 1px solid var(--color-line);
    border-radius: 1rem;
    overflow: hidden;
    transition:
      border-color 0.25s var(--ease-out),
      box-shadow 0.25s var(--ease-out);
  }

  /* Foto real de fondo (solo en servicios con `bg`) */
  .acc__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(90deg, transparent 30%, #000 100%);
    mask-image: linear-gradient(90deg, transparent 30%, #000 100%);
  }
  .acc__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 40%;
    opacity: 0.22;
    filter: saturate(1.05);
    transition:
      opacity 0.4s var(--ease-out),
      transform 0.6s var(--ease-out);
  }
  .acc[open] .acc__bg img {
    opacity: 0.42;
    transform: scale(1.04);
  }
  /* velo para que el texto siga legible sobre la foto */
  .acc[data-has-bg]::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      oklch(0.2 0.035 262 / 0.92) 30%,
      oklch(0.2 0.035 262 / 0.5) 100%
    );
  }
  .acc__summary,
  .acc__body {
    position: relative;
    z-index: 1;
  }
  .acc[open],
  .acc:hover {
    border-color: oklch(0.62 0.2 258 / 0.5);
  }
  .acc[open] {
    box-shadow: 0 20px 50px -30px oklch(0.62 0.2 258 / 0.8);
  }

  .acc__summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 1.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .acc__summary::-webkit-details-marker {
    display: none;
  }
  .acc__summary:focus-visible {
    outline: 2px solid var(--color-brand-glow);
    outline-offset: -2px;
  }

  .acc__icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    color: var(--color-brand-glow);
    background: oklch(0.62 0.2 258 / 0.14);
    border: 1px solid oklch(0.62 0.2 258 / 0.28);
    transition:
      transform 0.3s var(--ease-out),
      background-color 0.3s var(--ease-out);
  }
  .acc[open] .acc__icon {
    background: oklch(0.62 0.2 258 / 0.22);
    transform: scale(1.05);
  }

  .acc__head {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
    flex: 1;
  }
  .acc__title {
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--color-ink);
    line-height: 1.2;
  }
  .acc__resumen {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .acc__chevron {
    flex: none;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    color: var(--color-muted);
    transition:
      transform 0.32s var(--ease-out),
      color 0.2s var(--ease-out);
  }
  .acc[open] .acc__chevron {
    transform: rotate(180deg);
    color: var(--color-brand-glow);
  }

  .acc__body {
    padding: 0 1.25rem 1.25rem calc(1.25rem + 46px + 1rem);
  }
  .acc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    border-top: 1px solid var(--color-line);
    padding-top: 1.1rem;
  }
  .acc__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    color: var(--color-ink-soft);
    font-size: 0.96rem;
    line-height: 1.5;
  }
  .acc__list :global(svg) {
    flex: none;
    margin-top: 2px;
    color: var(--color-brand-glow);
  }

  /* Animación de apertura suave donde el navegador lo soporta */
  @supports (interpolate-size: allow-keywords) {
    :global(:root) {
      interpolate-size: allow-keywords;
    }
    .acc::details-content {
      height: 0;
      overflow: hidden;
      transition:
        height 0.36s var(--ease-drawer),
        content-visibility 0.36s allow-discrete;
    }
    .acc[open]::details-content {
      height: auto;
    }
  }

  @media (max-width: 520px) {
    .acc__body {
      padding-left: 1.25rem;
    }
    .acc__resumen {
      display: none;
    }
  }
</style>
