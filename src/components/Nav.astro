---
import { navLinks, waLink } from "@/data/site";
import { withBase } from "@/lib/paths";
import Icon from "./Icon.astro";
const path = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const isActive = (href: string) => {
  const h = withBase(href);
  return h === base ? path === base : path.startsWith(h);
};
---

<header id="site-nav" class="nav" transition:persist>
  <div class="container-x nav__inner">
    <a href={withBase("/")} class="nav__brand" aria-label="PLAY Egresados — Inicio">
      <img
        src={withBase("/img/logo-blanco-256.png")}
        alt="PLAY Egresados"
        width="118"
        height="36"
        fetchpriority="high"
      />
    </a>

    <nav class="nav__links" aria-label="Navegación principal">
      {
        navLinks.map((l) => (
          <a
            href={withBase(l.href)}
            class:list={["nav__link", { "is-active": isActive(l.href) }]}
            aria-current={isActive(l.href) ? "page" : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="nav__actions">
      <a
        href={waLink}
        target="_blank"
        rel="noopener"
        class="btn btn--wa nav__cta"
      >
        <Icon name="wa" size={19} />
        <span>WhatsApp</span>
      </a>
      <button
        id="nav-toggle"
        class="nav__burger"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu__inner">
      <div class="mobile-menu__pad">
      <nav class="mobile-menu__nav" aria-label="Navegación mobile">
        {
          navLinks.map((l, i) => (
            <a
              href={withBase(l.href)}
              class:list={[
                "mobile-menu__link",
                { "is-active": isActive(l.href) },
              ]}
              style={`--i:${i}`}
            >
              {l.label}
              <Icon name="arrow" size={20} />
            </a>
          ))
        }
      </nav>
      <a
        href={waLink}
        target="_blank"
        rel="noopener"
        class="btn btn--wa mobile-menu__cta"
      >
        <Icon name="wa" size={20} />
        <span>Escribinos por WhatsApp</span>
      </a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    transition:
      background-color 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out),
      backdrop-filter 0.3s var(--ease-out);
    border-bottom: 1px solid transparent;
  }
  /* Estado al hacer scroll (lo activa un script agregando .is-scrolled) */
  :global(.nav.is-scrolled) {
    background: oklch(0.15 0.028 262 / 0.72);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--color-line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 68px;
  }
  .nav__brand img {
    height: 34px;
    width: auto;
    transition: transform 0.2s var(--ease-out);
  }
  .nav__brand:active img {
    transform: scale(0.96);
  }

  .nav__links {
    display: none;
    gap: 0.35rem;
    margin-inline: auto;
  }
  .nav__link {
    position: relative;
    padding: 0.55rem 0.95rem;
    font-weight: 600;
    font-size: 0.96rem;
    color: var(--color-muted);
    border-radius: 999px;
    transition:
      color 0.2s var(--ease-out),
      background-color 0.2s var(--ease-out),
      transform 0.14s var(--ease-out);
  }
  .nav__link:hover {
    color: var(--color-ink);
    background: oklch(0.27 0.045 262 / 0.5);
  }
  .nav__link:active {
    transform: scale(0.95);
  }
  .nav__link.is-active {
    color: var(--color-ink);
  }
  .nav__link.is-active::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-brand-bright);
    transform: translateX(-50%);
    box-shadow: 0 0 10px 1px var(--color-brand-glow);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .nav__cta {
    display: none;
    padding: 0.65rem 1.1rem;
    font-size: 0.92rem;
    min-height: 44px;
  }
  .nav__burger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: oklch(0.23 0.04 262 / 0.6);
    border: 1px solid var(--color-line);
    color: var(--color-ink);
    cursor: pointer;
    transition:
      background-color 0.2s var(--ease-out),
      transform 0.16s var(--ease-out);
  }
  .nav__burger:active {
    transform: scale(0.94);
  }

  /* ---- Menú mobile: colapsa con grid-template-rows 0fr→1fr (sin layout thrash) ---- */
  .mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    background: oklch(0.15 0.028 262 / 0.96);
    backdrop-filter: blur(16px);
    transition: grid-template-rows 0.42s var(--ease-drawer);
  }
  .mobile-menu.is-open {
    grid-template-rows: 1fr;
    border-top: 1px solid var(--color-line);
  }
  .mobile-menu__inner {
    overflow: hidden;
    min-height: 0;
  }
  .mobile-menu__pad {
    padding: 0.5rem clamp(1.15rem, 5vw, 2.5rem) 1.4rem;
  }
  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
  }
  .mobile-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0.25rem;
    font-family: var(--font-display);
    font-size: 1.6rem;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--color-ink-soft);
    border-bottom: 1px solid var(--color-line);
  }
  .mobile-menu__link :global(svg) {
    color: var(--color-brand-bright);
    opacity: 0.5;
    transition: transform 0.2s var(--ease-out);
  }
  .mobile-menu__link.is-active {
    color: var(--color-brand-glow);
  }
  .mobile-menu__link:active :global(svg) {
    transform: translateX(4px);
  }
  .mobile-menu__cta {
    width: 100%;
    margin-top: 1.2rem;
  }
  /* Animación de entrada de items del menú */
  @media (prefers-reduced-motion: no-preference) {
    :global(.mobile-menu.is-open) .mobile-menu__link {
      animation: menu-item-in 0.5s var(--ease-out) both;
      animation-delay: calc(var(--i) * 55ms + 60ms);
    }
    @keyframes menu-item-in {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
    }
  }

  @media (min-width: 900px) {
    .nav__links {
      display: flex;
    }
    .nav__cta {
      display: inline-flex;
    }
    .nav__burger {
      display: none;
    }
  }
</style>
