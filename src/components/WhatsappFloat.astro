---
import { waLink } from "@/data/site";
import Icon from "./Icon.astro";
---

<a
  href={waLink}
  target="_blank"
  rel="noopener"
  class="wa-float"
  aria-label="Escribinos por WhatsApp"
  transition:persist
>
  <span class="wa-float__pulse" aria-hidden="true"></span>
  <Icon name="wa" size={30} />
  <span class="wa-float__label">Escribinos</span>
</a>

<style>
  .wa-float {
    position: fixed;
    right: clamp(1rem, 4vw, 1.75rem);
    bottom: clamp(1rem, 4vw, 1.75rem);
    z-index: var(--z-float);
    display: inline-flex;
    align-items: center;
    gap: 0;
    height: 60px;
    padding: 0 15px;
    border-radius: 999px;
    background: var(--color-wa);
    color: white;
    box-shadow:
      0 10px 30px -6px rgb(37 211 102 / 0.5),
      0 2px 8px rgb(0 0 0 / 0.3);
    transition:
      transform 0.22s var(--ease-out),
      box-shadow 0.22s var(--ease-out),
      padding 0.28s var(--ease-out);
  }
  .wa-float :global(svg) {
    flex: none;
    position: relative;
    z-index: 1;
  }
  .wa-float__label {
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    font-weight: 700;
    font-size: 0.98rem;
    opacity: 0;
    transition:
      max-width 0.32s var(--ease-out),
      opacity 0.24s var(--ease-out),
      margin 0.32s var(--ease-out);
  }
  .wa-float:active {
    transform: scale(0.95);
  }
  /* Halo pulsante */
  .wa-float__pulse {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--color-wa);
    z-index: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .wa-float__pulse {
      animation: wa-pulse 2.6s var(--ease-out) infinite;
    }
    @keyframes wa-pulse {
      0% {
        transform: scale(1);
        opacity: 0.5;
      }
      70%,
      100% {
        transform: scale(1.5);
        opacity: 0;
      }
    }
  }
  /* En desktop el botón revela la etiqueta al hover */
  @media (hover: hover) and (pointer: fine) {
    .wa-float:hover {
      box-shadow:
        0 14px 40px -6px rgb(37 211 102 / 0.65),
        0 2px 8px rgb(0 0 0 / 0.3);
    }
    .wa-float:hover .wa-float__label {
      max-width: 160px;
      opacity: 1;
      margin-left: 10px;
      margin-right: 4px;
    }
  }
</style>
