---
import Icon from "./Icon.astro";
import { djs } from "@/data/djs";
import { withBase } from "@/lib/paths";
---

<div class="djc" data-carousel>
  <div class="djc__track" data-carousel-track>
    {
      djs.map((dj, i) => (
        <article class="djslide">
          <div class="djslide__photo">
            <img
              src={withBase(dj.foto)}
              alt={`DJ ${dj.nombre} tocando en un evento de PLAY`}
              width="800"
              height="1000"
              loading={i < 2 ? "eager" : "lazy"}
            />
            {dj.instagram && (
              <a
                class="djslide__ig"
                href={dj.instagram}
                target="_blank"
                rel="noopener"
                aria-label={`Instagram de ${dj.nombre}`}
              >
                <Icon name="ig" size={18} />
              </a>
            )}
          </div>
          <div class="djslide__info">
            <span class="djslide__role">
              <Icon name="music" size={14} />
              {dj.rol}
            </span>
            <h2 class="djslide__name font-display">{dj.nombre}</h2>
          </div>
        </article>
      ))
    }
  </div>

  <div class="djc__controls">
    <button
      class="djc__btn"
      data-carousel-prev
      aria-label="DJ anterior"
      disabled
    >
      <Icon name="arrow" size={22} class="djc__btn-icon djc__btn-icon--left" />
    </button>
    <button class="djc__btn" data-carousel-next aria-label="Siguiente DJ">
      <Icon name="arrow" size={22} />
    </button>
  </div>
</div>

<style>
  .djc {
    position: relative;
  }
  .djc__track {
    display: flex;
    gap: 1.15rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    /* deja respirar el snap en los bordes */
    scroll-padding-inline: 0;
  }
  .djc__track::-webkit-scrollbar {
    display: none;
  }

  .djslide {
    position: relative;
    flex: 0 0 82%;
    scroll-snap-align: start;
    border-radius: 1.15rem;
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
  }
  .djslide__photo {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .djslide__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }
  .djslide:hover .djslide__photo img {
    transform: scale(1.05);
  }
  .djslide__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 42%,
      oklch(0.15 0.028 262 / 0.92)
    );
  }
  .djslide__ig {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    color: white;
    background: oklch(0.2 0.03 262 / 0.55);
    backdrop-filter: blur(8px);
    border: 1px solid oklch(0.8 0.05 262 / 0.35);
    transition:
      transform 0.2s var(--ease-out),
      background-color 0.2s var(--ease-out);
  }
  .djslide__ig:hover {
    transform: translateY(-2px) scale(1.05);
    background: linear-gradient(140deg, #f9407c, #b026ff 60%, #ffb13d);
  }
  .djslide__ig:active {
    transform: scale(0.92);
    transition-duration: 0.11s;
  }
  @media (hover: none) {
    .djslide:hover .djslide__photo img {
      transform: none;
    }
  }
  .djslide__info {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    padding: 1.1rem 1.2rem 1.3rem;
  }
  .djslide__role {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-brand-glow);
    margin-bottom: 0.45rem;
  }
  .djslide__name {
    font-size: clamp(1.3rem, 5vw, 1.75rem);
    color: var(--color-ink);
    line-height: 1;
    margin: 0;
  }

  /* Controles */
  .djc__controls {
    display: flex;
    justify-content: flex-end;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
  .djc__btn {
    display: grid;
    place-items: center;
    width: 50px;
    height: 50px;
    border-radius: 14px;
    color: var(--color-ink);
    background: oklch(0.23 0.04 262 / 0.7);
    border: 1px solid var(--color-line);
    cursor: pointer;
    transition:
      transform 0.16s var(--ease-out),
      background-color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      opacity 0.2s var(--ease-out);
  }
  .djc__btn:hover:not(:disabled) {
    border-color: var(--color-brand-bright);
    background: oklch(0.27 0.045 262 / 0.8);
  }
  .djc__btn:active:not(:disabled) {
    transform: scale(0.93);
  }
  .djc__btn:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .djc__btn-icon--left {
    transform: rotate(180deg);
  }

  @media (min-width: 640px) {
    .djslide {
      flex-basis: 46%;
    }
  }
  @media (min-width: 960px) {
    .djslide {
      flex-basis: calc((100% - 2 * 1.15rem) / 3);
    }
  }
</style>
