---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import SEO from "@/components/SEO.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import WhatsappFloat from "@/components/WhatsappFloat.astro";
import { withBase } from "@/lib/paths";

interface Props {
  title: string;
  description: string;
  path?: string;
}
const { title, description, path } = Astro.props;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b0e17" />
    <link rel="icon" href={withBase("/favicon.png")} type="image/png" />
    <link
      rel="icon"
      href={withBase("/favicon-32.png")}
      sizes="32x32"
      type="image/png"
    />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <meta name="generator" content={Astro.generator} />

    {/* Marca JS activo antes del primer paint: habilita los reveals sin FOUC.
        Sin JS, el contenido se muestra igual (no queda oculto). */}
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <SEO title={title} description={description} path={path} />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar al contenido</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsappFloat />

    <script>
      import "@/scripts/site.ts";
    </script>

    <style>
      .skip-link {
        position: fixed;
        top: -60px;
        left: 12px;
        z-index: var(--z-toast);
        padding: 0.7rem 1.1rem;
        background: var(--color-brand-bright);
        color: white;
        border-radius: 10px;
        font-weight: 700;
        transition: top 0.2s var(--ease-out);
      }
      .skip-link:focus {
        top: 12px;
      }
    </style>
  </body>
</html>
