---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { site, waLink, zonas } from "@/data/site";
---

<BaseLayout
  title="Contacto — pedí tu presupuesto"
  description="Escribinos por WhatsApp para tu previa, UPD o prefiesta de egresados en CABA. Instagram @playegresados_. Contanos tu colegio y curso y te armamos el presupuesto."
  path="/contacto/"
>
  <section class="page-hero">
    <div class="container-x">
      <span class="chip reveal">
        <Icon name="spark" size={15} />
        Estamos para ayudarte
      </span>
      <h1 class="page-hero__title font-display reveal" style="--i:1">
        Hablemos
      </h1>
      <p class="page-hero__lead reveal" style="--i:2">
        La forma más rápida es por WhatsApp. Contanos tu colegio, curso y qué
        etapa querés producir, y te enviamos el presupuesto con todo lo que
        incluye.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x contacto">
      {/* --- Columna de contacto directo --- */}
      <div class="contacto__side">
        <a
          href={waLink}
          target="_blank"
          rel="noopener"
          class="wa-big reveal"
        >
          <span class="wa-big__icon"><Icon name="wa" size={30} /></span>
          <span class="wa-big__text">
            <strong>Escribinos por WhatsApp</strong>
            <span>Respondemos rápido</span>
          </span>
          <Icon name="arrow" size={20} class="wa-big__arrow" />
        </a>

        <a
          href={site.instagram}
          target="_blank"
          rel="noopener"
          class="contacto__ig reveal"
          style="--i:1"
        >
          <span class="contacto__ig-icon"><Icon name="ig" size={24} /></span>
          <span>
            <strong>Instagram</strong>
            <span>{site.instagramHandle}</span>
          </span>
        </a>

        <div class="contacto__zonas reveal" style="--i:2">
          <h3><Icon name="map" size={18} /> Operamos en CABA</h3>
          <ul>
            {zonas.map((z) => <li>{z}</li>)}
          </ul>
        </div>
      </div>

      {/* --- Formulario --- */}
      <form
        id="contact-form"
        class="form reveal"
        style="--i:1"
        data-wa={site.whatsappNumber}
        novalidate
      >
        <h2 class="form__title">Dejanos tu consulta</h2>
        <p class="form__hint">
          Completá el formulario y se abre WhatsApp con tu mensaje listo para
          enviar.
        </p>

        <div class="field">
          <label for="nombre">Nombre <span aria-hidden="true">*</span></label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            autocomplete="name"
            required
            placeholder="Tu nombre y apellido"
          />
          <p class="field__error" data-error-for="nombre">
            Contanos tu nombre.
          </p>
        </div>

        <div class="field">
          <label for="colegio">Colegio / curso <span aria-hidden="true">*</span></label>
          <input
            id="colegio"
            name="colegio"
            type="text"
            required
            placeholder="Ej: Colegio San José, 5º B"
          />
          <p class="field__error" data-error-for="colegio">
            Decinos tu colegio y curso.
          </p>
        </div>

        <div class="field">
          <label for="mensaje">Mensaje</label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows="4"
            placeholder="Contanos qué etapa querés producir (previa, UPD, UVI…) y para cuándo."
          ></textarea>
        </div>

        <button type="submit" class="btn btn--wa form__submit">
          <Icon name="wa" size={20} />
          <span>Enviar por WhatsApp</span>
        </button>

        <div id="form-success" class="form__success" role="status" aria-live="polite" hidden>
          <span class="form__success-icon"><Icon name="check" size={20} /></span>
          <p>
            <strong>¡Listo!</strong> Te abrimos WhatsApp con tu mensaje. Si no se
            abrió,
            <a id="form-success-link" href="#" target="_blank" rel="noopener"
              >tocá acá</a
            >.
          </p>
        </div>

        <p class="form__note">
          También podés escribirnos directo por WhatsApp o Instagram.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contacto {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }

  /* Columna lateral */
  .contacto__side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .wa-big {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.35rem 1.4rem;
    border-radius: 1.1rem;
    background: linear-gradient(140deg, var(--color-wa), var(--color-wa-dark));
    color: white;
    box-shadow: 0 16px 40px -18px rgb(37 211 102 / 0.8);
    transition:
      transform 0.2s var(--ease-out),
      box-shadow 0.24s var(--ease-out);
  }
  .wa-big:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 50px -18px rgb(37 211 102 / 0.9);
  }
  .wa-big:active {
    transform: scale(0.98);
  }
  .wa-big__icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: rgb(255 255 255 / 0.18);
  }
  .wa-big__text {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .wa-big__text strong {
    font-size: 1.1rem;
  }
  .wa-big__text span {
    font-size: 0.88rem;
    opacity: 0.9;
  }
  .wa-big__arrow {
    margin-left: auto;
    transition: transform 0.2s var(--ease-out);
  }
  .wa-big:hover .wa-big__arrow {
    transform: translateX(4px);
  }

  .contacto__ig {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 1.4rem;
    border-radius: 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    color: var(--color-ink-soft);
    transition:
      transform 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out);
  }
  .contacto__ig:hover {
    transform: translateY(-3px);
    border-color: oklch(0.62 0.2 258 / 0.5);
  }
  .contacto__ig:active {
    transform: scale(0.98);
    transition-duration: 0.11s;
  }
  @media (hover: none) {
    .wa-big:hover,
    .contacto__ig:hover {
      transform: none;
    }
  }
  .contacto__ig strong {
    display: block;
    color: var(--color-ink);
  }
  .contacto__ig span span {
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .contacto__ig-icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 50px;
    height: 50px;
    border-radius: 13px;
    color: white;
    background: linear-gradient(140deg, #f9407c, #b026ff 60%, #ffb13d);
  }

  .contacto__zonas {
    padding: 1.35rem 1.4rem;
    border-radius: 1.1rem;
    background: oklch(0.19 0.035 262 / 0.5);
    border: 1px solid var(--color-line);
  }
  .contacto__zonas h3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink);
    margin: 0 0 0.9rem;
  }
  .contacto__zonas h3 :global(svg) {
    color: var(--color-brand-glow);
  }
  .contacto__zonas ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .contacto__zonas li {
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brand-glow);
    background: oklch(0.62 0.2 258 / 0.12);
    border: 1px solid oklch(0.62 0.2 258 / 0.25);
  }

  /* Formulario */
  .form {
    padding: clamp(1.5rem, 4vw, 2.25rem);
    border-radius: 1.25rem;
    background: linear-gradient(
      180deg,
      oklch(0.24 0.05 262 / 0.6),
      oklch(0.17 0.03 262 / 0.6)
    );
    border: 1px solid var(--color-line);
  }
  .form__title {
    font-size: 1.5rem;
    margin: 0;
  }
  .form__hint {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin: 0.5rem 0 1.5rem;
  }
  .field {
    margin-bottom: 1.15rem;
  }
  .field label {
    display: block;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    margin-bottom: 0.45rem;
  }
  .field label span {
    color: var(--color-brand-glow);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border-radius: 0.7rem;
    background: oklch(0.15 0.028 262 / 0.7);
    border: 1px solid var(--color-line);
    color: var(--color-ink);
    font: inherit;
    font-size: 1rem;
    min-height: 48px;
    transition:
      border-color 0.2s var(--ease-out),
      box-shadow 0.2s var(--ease-out);
  }
  .field textarea {
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: oklch(0.6 0.02 262);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-brand-bright);
    box-shadow: 0 0 0 3px oklch(0.62 0.2 258 / 0.22);
  }
  .field__error {
    display: none;
    align-items: center;
    gap: 0.35rem;
    margin: 0.45rem 0 0;
    font-size: 0.85rem;
    color: oklch(0.72 0.17 25);
  }
  .field.has-error input,
  .field.has-error textarea {
    border-color: oklch(0.6 0.2 25);
  }
  .field.has-error .field__error {
    display: flex;
  }
  .form__submit {
    width: 100%;
    margin-top: 0.5rem;
  }
  .form__note {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.85rem;
    margin: 1rem 0 0;
  }
  .form__success {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: 0.8rem;
    background: rgb(37 211 102 / 0.12);
    border: 1px solid rgb(37 211 102 / 0.35);
  }
  .form__success[hidden] {
    display: none;
  }
  .form__success-icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: white;
    background: var(--color-wa);
  }
  .form__success p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
  }
  .form__success strong {
    color: var(--color-ink);
  }
  .form__success a {
    color: var(--color-wa);
    font-weight: 700;
    text-decoration: underline;
  }
  @media (prefers-reduced-motion: no-preference) {
    .form__success {
      animation: form-success-in 0.4s var(--ease-out) both;
    }
    @keyframes form-success-in {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
    }
  }

  @media (min-width: 860px) {
    .contacto {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 2rem;
    }
  }
</style>
