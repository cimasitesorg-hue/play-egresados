---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { waLink } from "@/data/site";
import { withBase } from "@/lib/paths";
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscás no existe. Volvé al inicio o escribinos por WhatsApp."
  path="/404/"
>
  <section class="nf">
    <div class="container-x nf__inner">
      <span class="nf__code font-display">404</span>
      <h1 class="nf__title">Esta página se fue de previa</h1>
      <p class="nf__text">
        No encontramos lo que buscabas. Volvé al inicio o escribinos y te
        ayudamos.
      </p>
      <div class="nf__actions">
        <a href={withBase("/")} class="btn">
          <Icon name="arrow" size={18} />
          Volver al inicio
        </a>
        <a href={waLink} target="_blank" rel="noopener" class="btn btn--wa">
          <Icon name="wa" size={19} />
          <span>WhatsApp</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: 70svh;
    display: grid;
    place-items: center;
    text-align: center;
    padding-block: 4rem;
  }
  .nf__code {
    font-size: clamp(5rem, 22vw, 11rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 2px oklch(0.62 0.2 258 / 0.6);
    text-shadow: 0 0 60px oklch(0.62 0.2 258 / 0.4);
  }
  .nf__title {
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    margin: 0.5rem 0 0;
  }
  .nf__text {
    max-width: 42ch;
    margin: 1rem auto 0;
    color: var(--color-muted);
  }
  .nf__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
